# Local virtualenvs
.venv/
venv/

# Auto-simulated input datasets — regenerated by profiler scripts, not committed.
# These regenerate BYTE-IDENTICAL to the removed committed copies (verified per
# instrument: imaging euclid/jwst/ao, interferometer sma) via
# _profile_cli.auto_simulate_if_missing -> scripts/misc/simulators/<type>.py.
# Datasets that do NOT regenerate byte-identically remain tracked and are NOT
# covered by these rules: imaging/hst (stale re-mirror), imaging/source_complex
# (no producing simulator), interferometer/alma + alma_high (NUFFT float
# non-determinism), interferometer/alma_high_res + hannah (no producing
# simulator), point_source/simple/*.json (non-deterministic serialization).
dataset/cluster/
dataset/group/
dataset/group4_mge/
dataset/imaging/group4_mge/
dataset/multi/
dataset/imaging/simple/
dataset/imaging/euclid/
dataset/imaging/jwst/
dataset/imaging/ao/
dataset/interferometer/simple/
dataset/interferometer/sma/
dataset/point_source/simple/data.fits
dataset/point_source/simple/noise_map.fits
dataset/point_source/simple/psf.fits
dataset/point_source/simple/point_dataset_positions_only.csv

# Datacube simulator outputs — regenerated each run
dataset/datacube/sim_*/

# Lensed-source adapt images — produced by simulators and cached on-demand
# by likelihood/adapt_image_util.py. Regeneratable from tracer.json on first
# script run; kept out of git so different machines don't fight over a file
# that's purely an auto-cache.
dataset/**/lensed_source.fits

# Retired legacy results section (pre likelihood_runtime/breakdown split);
# nothing writes here since the phase-2 output retarget. Kept ignored so old
# local checkouts don't surface stale artifacts as untracked.
results/likelihood/

# Retired legacy latent output home (latent now writes results/latent/, in-repo).
latent/results/
