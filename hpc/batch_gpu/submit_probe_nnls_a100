#!/bin/bash -l
#
# NNLS solver probe + post-#368 breakdown re-baseline — PyAutoArray#369.
#
# Three measurements on one A100, all writing into scratch/nnls_speedup/
# (standalone Phase A dir — results are pulled back by rsync, not git):
#
#   1. probe_pdip.py on the REAL extracted rect/Delaunay HST systems
#      (rsynced .npz) — PDIP iteration counts, tolerance ladder, per-
#      iteration Cholesky cost and the vmap max-lane effect, on-GPU.
#   2. scripts/imaging/likelihood_breakdown/pixelization.py — A100 per-step shares
#      of the rect pixelization+MGE eval (the NNLS share headline number).
#   3. scripts/imaging/likelihood_breakdown/delaunay.py — same for Delaunay; also
#      clears the outstanding "A100 re-profile post-#368" item from the
#      Delaunay callback review (PyAutoArray#367).

#SBATCH -J probe_nnls_a100
#SBATCH --partition=gpu
#SBATCH --gres=gpu:1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=4
#SBATCH --mem=64gb
#SBATCH --time=2:00:00
#SBATCH -o output/output.%A.out
#SBATCH -e error/error.%A.err
#SBATCH --mail-type=END,FAIL
#SBATCH --mail-user=james.w.nightingale@durham.ac.uk

export AP_ROOT=/mnt/ral/jnightin/autolens_profiling
source $AP_ROOT/activate.sh

export JAX_PLATFORM_NAME=cuda
export JAX_PLATFORMS=cuda,cpu
export XLA_PYTHON_CLIENT_PREALLOCATE=false
export JAX_ENABLE_X64=True
export NUMBA_CACHE_DIR=/tmp/numba_cache
export MPLCONFIGDIR=/tmp/matplotlib

nvidia-smi
cd $AP_ROOT

run_step () {
    echo "=== $* ==="
    date
    "$@" || echo "!!! step FAILED: $*"
}

run_step python3 scratch/nnls_speedup/probe_pdip.py --mesh rectangular \
    2>&1 | tee scratch/nnls_speedup/probe_rect_a100.log
run_step python3 scratch/nnls_speedup/probe_pdip.py --mesh delaunay \
    2>&1 | tee scratch/nnls_speedup/probe_delaunay_a100.log

run_step python3 scripts/imaging/likelihood_breakdown/pixelization.py \
    --output-dir scratch/nnls_speedup/a100 \
    2>&1 | tee scratch/nnls_speedup/rect_breakdown_a100.log
run_step python3 scripts/imaging/likelihood_breakdown/delaunay.py \
    --output-dir scratch/nnls_speedup/a100 \
    2>&1 | tee scratch/nnls_speedup/delaunay_breakdown_a100.log

echo "Finished."
date
